rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny Rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /peserta/{pesertaId} {
      allow read: if true;
      allow write: if isSignedIn() || true; // Server-side writes are allowed
    }

    match /logs/{logId} {
      allow read: if true;
      allow write: if isSignedIn() || true;
    }

    match /jadwal/{jadwalId} {
      allow read: if true;
      allow write: if isSignedIn() || true;
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isSignedIn() || true;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSignedIn() || true;
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn() || true;
    }
  }
}
